{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://heritagesamples.org/schema/VocabularyConcept/v0.9.schema.json",
    "title": "VocabularyConcept",
    "type": "object",
    "required": ["id", "prefLabel", "terms"],
    "properties": {
        "id": {
            "type": "string",
            "cordra": {
                "type": {
                    "autoGeneratedField": "handle"
                }
            }
        },
        "prefLabel": {
            "title": "Language-neutral label",
            "description": "Language-neutral label of the concept",
            "type": "string",
            "minLength": 1,
            "cordra": {
                "preview": {
                    "showInPreview": true,
                    "isPrimary": true
                }
            }
        },
        "terms": {
            "title": "Terms",
            "description": "Terms in different languages, with one preferred label per language",
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["label", "lang", "isAlternative"],
                "properties": {
                    "label": {
                        "title": "Term",
                        "description": "The term in the specified language",
                        "type": "string",
                        "minLength": 1
                    },
                    "lang": {
                        "title": "Language",
                        "description": "The language of the term",
                        "type": "string"
                    },
                    "isAlternative": {
                        "title": "Alternative label",
                        "description": "Whether this term is an alternative label for its language",
                        "type": "boolean",
                        "default": false
                    }
                }
            }
        },
        "descriptions":{
            "title": "Descriptions",
            "description": "Descriptions of the concept in different languages",
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "description": {
                        "title": "Description",
                        "type": "string",
                        "format": "textarea"
                    },
                    "lang": {
                        "title": "Language",
                        "type": "string"
                    }
                }
            }
        },
        "broader": {
            "title": "Broader concepts",
            "description": "Broader concepts of the current concept",
            "type": "array",
            "items": {
                "title": "Broader concept",
                "type": "string",
                "cordra": {
                    "type": {
                        "handleReference": {
                            "types": ["VocabularyConcept"]
                        }
                    }
                }
            }
        },
        "narrower": {
            "title": "Narrower concepts",
            "description": "Narrower concepts of the current concept",
            "type": "array",
            "items": {
                "type": "string",
                "cordra": {
                    "type": {
                        "handleReference": {
                            "types": ["VocabularyConcept"]
                        }
                    }
                }
            }
        },
        "exactMatch": {
            "title": "Exact match",
            "description": "Exact match to the concept in another vocabulary",
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "uri": {
                        "title": "URI",
                        "description": "URI of the exact match",
                        "type": "string",
                        "format": "uri"
                    },
                    "scheme": {
                        "title": "Scheme",
                        "description": "Scheme of the exact match",
                        "type": "string"
                    },
                    "primarySource": {
                        "title": "Primary source",
                        "description": "Primary source of the exact match",
                        "type": "boolean"
                    }
                }
            }
        },
        "queryTerms": {
            "title": "Query terms",
            "description": "Query terms that define subsets concepts, to be used as a controlled list",
            "type": "array",
            "items": {
                "title": "Name",
                "description": "Name of the enumeration",
                "type": "string"
            }
        }
    }
}