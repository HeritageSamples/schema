{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://heritagesamples.org/schema/JavaScriptDirectory/v0.9",
    "title": "JavaScriptDirectory",
    "type": "object",
    "required": ["directory"],
    "properties": {
        "id": {
            "type": "string",
            "cordra": {
                "type": {
                    "autoGeneratedField": "handle"
                }
            }
        },
        "directory": {
            "type": "string",
            "title": "Directory",
            "cordra": {
                "referrable": {
                    "id": true,
                    "payloads": "scripts"
                }
            }
        }
    }
}
