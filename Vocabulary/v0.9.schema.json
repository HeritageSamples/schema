{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://heritagesamples.org/schema/Vocabulary/v0.9",
    "title": "Vocabulary",
    "description": "SKOS ConceptScheme metadata for VocabularyConcept records.",
    "type": "object",
    "required": ["id", "notation", "uri", "prefLabel"],
    "properties": {
        "id": {
            "type": "string",
            "cordra": {
                "type": {
                    "autoGeneratedField": "handle"
                }
            }
        },
        "$schema": {
            "type": "string",
            "options": {
                "hidden": true
            }
        },
        "notation": {
            "title": "Notation",
            "description": "Stable short code for this vocabulary, e.g. aat, titleType.",
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9_:-]+$"
        },
        "uri": {
            "title": "Scheme URI",
            "description": "Canonical URI of this SKOS ConceptScheme.",
            "type": "string",
            "format": "uri"
        },
        "prefLabel": {
            "title": "Preferred label",
            "description": "Preferred labels (skos:prefLabel). At most one entry per language.",
            "$ref": "#/$defs/skosLabelArray"
        },
        "definition": {
            "title": "Definition",
            "description": "Definitions of the vocabulary (skos:definition). At most one entry per language.",
            "$ref": "#/$defs/skosTextArray"
        },
        "homepage": {
            "title": "Homepage",
            "description": "Public homepage of the vocabulary or source.",
            "type": "string",
            "format": "uri"
        },
        "sourceSystem": {
            "title": "Source system",
            "description": "System from which this vocabulary is harvested or managed.",
            "type": "string"
        },
        "sourceName": {
            "title": "Source name",
            "description": "Human-readable name of the source vocabulary.",
            "type": "string"
        },
        "sourceVersion": {
            "title": "Source version",
            "description": "Version or release label of the source data.",
            "type": "string"
        },
        "creditLine": {
            "title": "Credit line",
            "description": "Attribution line for the vocabulary.",
            "type": "string"
        },
        "database": {
            "title": "Source database",
            "description": "Source dataset identifier.",
            "type": "string"
        },
        "curiePrefix": {
            "title": "CURIE prefix",
            "description": "Prefix used for concept notations in this vocabulary.",
            "type": "string",
            "pattern": "^[a-z0-9_:-]+$"
        },
        "queryTerm": {
            "title": "Query term",
            "description": "Subset or harvest query tag applied to concepts from this vocabulary.",
            "type": "string"
        },
        "_mainTitle": {
            "title": "Main title",
            "description": "Automatically generated main title based on labels and notation.",
            "type": "string",
            "cordra": {
                "preview": {
                    "showInPreview": true,
                    "isPrimary": true
                },
                "disableInUi": true
            }
        }
    },
    "$defs": {
        "skosLabelEntry": {
            "type": "object",
            "required": ["label", "lang"],
            "properties": {
                "label": {
                    "title": "Label",
                    "type": "string",
                    "minLength": 1
                },
                "lang": {
                    "title": "Language",
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "skosLabelArray": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/skosLabelEntry" }
        },
        "skosTextEntry": {
            "type": "object",
            "required": ["text", "lang"],
            "properties": {
                "text": {
                    "title": "Text",
                    "type": "string",
                    "format": "textarea"
                },
                "lang": {
                    "title": "Language",
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "skosTextArray": {
            "type": "array",
            "items": { "$ref": "#/$defs/skosTextEntry" }
        }
    }
}
