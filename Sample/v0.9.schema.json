{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://heritagesamples.org/schema/Sample/v0.9.schema.json",
    "title": "Sample",
    "type": "object",
    "required": [
        "id",
        "types",
        "custodianIdentifier",
        "sampleSource",
        "creators",
        "custodian",
        "publisher",
        "dates"
    ],
    "properties": {
        "id": {
            "title": "Sample identifier",
            "description": "The identifier property will be automatically populated with a DOI upon the creation of an IGSN ID. The system will assign a random DOI suffix unless a specific suffix is supplied using Fabrica or DataCite APIs.",
            "type": "string",
            "cordra": {
                "type": {
                    "autoGeneratedField": "handle"
                }
            }
        },
        "doi": {
            "title": "DOI",
            "type": "string",
            "format": "uri",
            "$comment": "idea to have samples with an id, but without a DOI (yet)??? It might be an issue that this separate doi field cannot be set read-only",
            "cordra": {
                "preview": {
                    "showInPreview": true
                }
            }
        },
        "$comment": {

            "title": "Resource types",
            "type": "object",
            "description": "The resourceType property may be populated with resource types from external ontologies or shared vocabularies. In the absence of an agreed vocabulary, the use of the terms “material sample” or “‘feature-of-interest” are strongly recommended to at least distinguish between these sampling concepts. A material sample is a specialization of a larger feature-of-interest, which is typically the collection site. For example, in the Geosciences, a feature-of-interest might be a lake, tree, cross-section, transect, or borehole. ",
            "additionalProperties": false,
            "required": ["resourceType", "resourceTypeGeneral"],
            "properties": {
                "resourceType": {
                    "title": "Resource Type",
                    "type": "string",
                    "enum": [
                        "Heritage Sample",
                        "Heritage Feature-of-Interest",
                        "Heritage Sample Collection"
                    ],
                    "$comment": "https://support.datacite.org/docs/igsn-id-metadata-recommendations#10-resourcetype"
                },
                "resourceTypeGeneral": {
                    "type": "string",
                    "const": "PhysicalObject",
                    "default": "PhysicalObject",
                    "$comment": "https://support.datacite.org/docs/igsn-id-metadata-recommendations#10a-resourcetypegeneral"
                }
            }
        },
        "custodianIdentifier": {
            "title": "Sample name or label",
            "type": "string",
            "minLength": 1,
            "description": "The primary name, code or label assigned by the organisation responsible for the sample.",
            "cordra": {
                "preview": {
                    "showInPreview": true,
                    "isPrimary": true
                }
            }
        },
        "titles": {
            "title": "Alternative sample names or labels",
            "type": "array",
            "description": "Alternative names, codes or labels assigned by the organisation responsible for the sample.",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "title": "Sample title",
                "type": "object",
                "required": ["title", "titleType"],
                "additionalProperties": false,
                "properties": {
                    "title": {
                        "type": "string",
                        "cordra": {
                            "preview": {
                                "showInPreview": true
                            }
                        }
                    },
                    "titleType": {
                        "type": "string",
                        "enum": [
                            "Title",
                            "AlternativeTitle",
                            "Subtitle",
                            "TranslatedTitle",
                            "Other"
                        ],
                        "default": "Title",
                        "$comment": "https://datacite-metadata-schema.readthedocs.io/en/4.6/properties/title/#a-titletype"
                    },
                    "lang": {
                        "$ref": "https://e-rihs.io/schema/controlled_lists.schema.json#/definitions/operating_language"
                    }
                }
            }
        },
        "sampleSource": {
            "title": "Sample Source",
            "type": "object",
            "description": "The source of the sample",
            "required": ["sourceId"],
            "minProperties": 2,
            "properties": {
                "sourceId": {
                    "title": "Source ID",
                    "type": "string",
                    "description": "The ID of the heritage object from which the sample was taken",
                    "cordra": {
                        "type": {
                            "handleReference": {
                                "types": ["HeritageObject", "Sample"]
                            }
                        }
                    },
                    "$comment": "(1) not using in-cordra references, (2)maps to relatedIdentifiers type isDerivedFrom"
                },
                "sampleSiteDescription": {
                    "title": "Sample Site Description",
                    "type": "string",
                    "description": "A description of the location of the sample on the source object"
                },
                "sampleSiteAnnotationUrl": {
                    "title": "Sample Site Annotations",
                    "description": "A URL to document to location of the site relative to an image of the source. It is recommended to use a link to a IIIF manifest, or a PID landing page for further documentation.",
                    "type": "string",
                    "format": "uri"
                }
            }
        },
        "otherDescriptions": {
            "title": "Other Descriptions",
            "description": "It is valuable to include additional information about a sample, particularly about its 'birth', in the free-text description property. If the description property is used, then the sub-property descriptionType is mandatory.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["description", "descriptionType"],
                "properties": {
                    "description": {
                        "title": "Description",
                        "type": "string",
                        "format": "textarea"
                    },
                    "descriptionType": {
                        "title": "Description Type",
                        "type": "string",
                        "enum": [
                            "Sample description",
                            "Sampling method",
                            "Reason for sampling",
                            "Other"
                        ],
                        "$comment": "The custom descriptionType values used here map to standard DataCite types as follows: 'Sample description' and 'Sample site description' should both be treated as 'Abstract'; 'Sampling method' maps to 'Methods'; and 'Reason for sampling' maps to 'Other'. Note that a 'Sample site description' can be added in the 'sample_source' custom block, so it should not be added in this 'descriptions' array. These mappings should be applied when exporting to systems that expect standard DataCite descriptionType values."
                    },
                    "lang": {
                        "$ref": "https://e-rihs.io/schema/controlled_lists.schema.json#/definitions/operating_language"
                    }
                }
            }
        },
        "geoLocations": {
            "title": "Geo Locations",
            "description": "Geolocation where the sample is currently located - hidden from the user for now; if the custodian has a geolocation, it can be mirrored here",
            "options": {
                "hidden": true
            },
            "$ref": "https://heritagesamples.org/schema/Definitions.schema.json#/definitions/geoJsonFeature"
        },
        "sizes": {
            "title": "Sizes",
            "description": "The dimensions of the sample. This is a list of sizes in a unit of measure. This can be width, height, depth, diameter, weight, volume, etc. Use SI units as appropriate.",
            "type": "array",
            "items": {
                "type": "string"
            },
            "uniqueItems": true
        },
        "creators": {
            "title": "Creators",
            "type": "array",
            "description": "The creators are the people or organisations that created, collected or processed the sample.",
            "items": {
                "title": "Person",
                "type": "string",
                "cordra": {
                    "type": {
                        "handleReference": {
                            "types": ["Person", "Organisation"]
                        }
                    }
                }
            }
        },
        "custodian": {
            "title": "Custodian",
            "description": "The custodian organisation is the organisation or person that hosts the sample.",
            "type": "string",
            "$comment": "maps to contributor with type HostingInstitution",
            "cordra": {
                "type": {
                    "handleReference": {
                        "types": ["Organisation", "Person"]
                    }
                }
            }
        },
        "publisher": {
            "title": "Publisher",
            "description": "The publisher is the organisation or person that publishes the record.",
            "type": "string",
            "cordra": {
                "type": {
                    "handleReference": {
                        "types": ["Organisation"]
                    }
                }
            }
        },
        "publicationYear": {
            "title": "Publication Year",
            "description": "The publication year is the year when the record was first made available to the research community.",
            "type": "string",
            "pattern": "^[0-9]{4}$"
        },
        "dates": {
            "title": "Dates",
            "description": "Associated dates for the sample. If the date is not known precisely, use the first of January of the year to indicate the year.",
            "type": "object",
            "required": ["publishedDate"],
            "properties": {
                "collectedDate": {
                    "title": "Collected Date",
                    "description": "The collected date is the date when the sample was collected.",
                    "type": "string",
                    "format": "date"
                },
                "mountedDate": {
                    "title": "Mounted Date",
                    "description": "The mounted date is the date when the sample was mounted.",
                    "type": "string",
                    "format": "date"
                },
                "consumedDate": {
                    "title": "Consumed Date",
                    "description": "The consumed date is the date when the sample was consumed.",
                    "type": "string",
                    "format": "date"
                },
                "destroyedDate": {
                    "title": "Destroyed Date",
                    "description": "The destroyed date is the date when the sample was destroyed.",
                    "type": "string",
                    "format": "date"
                },
                "publishedDate": {
                    "title": "Published Date",
                    "description": "The published date is the date when the record was published.",
                    "type": "string",
                    "format": "date"
                }
            }
        },
        "documentationIdentifier": {
            "title": "Documentation Identifier",
            "description": "This is the principal identifier for the original documentation registry of the sample.",
            "$comment": "maps to datacite relatedIdentifier",
            "type": "object",
            "additionalProperties": false,
            "required": [
                "relatedIdentifier",
                "relatedIdentifierType",
                "relationType",
                "resourceTypeGeneral"
            ],
            "properties": {
                "relatedIdentifier": {
                    "title": "Related Identifier",
                    "type": "string"
                },
                "relatedIdentifierType": {
                    "title": "Related Identifier Type",
                    "type": "string",
                    "enum": [
                        "ARK",
                        "arXiv",
                        "bibcode",
                        "DOI",
                        "EAN13",
                        "EISSN",
                        "Handle",
                        "IGSN",
                        "ISBN",
                        "ISSN",
                        "ISTC",
                        "LISSN",
                        "LSID",
                        "PMID",
                        "PURL",
                        "UPC",
                        "URL",
                        "URN",
                        "w3id"
                    ]
                },
                "relationType": {
                    "title": "Relation Type",
                    "description": "The relatedIdentifier property can be used to make connections that mirror sample hierarchies. Because the parent IGSN ID is a key element in IGSN ID metadata, it is recommended that a child (sub)sample identifies its parent using the relationType 'IsPartOf' or 'IsDerivedFrom'. Vice versa, a parent sample can identify its children using 'HasPart' or 'IsSourceOf'.",
                    "type": "string",
                    "enum": ["IsDocumentedBy"],
                    "default": "IsDocumentedBy"
                },
                "resourceTypeGeneral": {
                    "title": "Resource Type General",
                    "type": "string",
                    "enum": ["Other"],
                    "default": "Other"
                }
            }
        },
        "alternateIdentifiers": {
            "title": "Alternate Identifiers",
            "description": "The alternateIdentifier property may be used to enter any other identifiers for the material sample, including local sample identifiers.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Alternate Identifier",
                "type": "object",
                "additionalProperties": false,
                "required": ["alternateIdentifier", "alternateIdentifierType"],
                "properties": {
                    "alternateIdentifier": {
                        "title": "Alternate Identifier",
                        "type": "string"
                    },
                    "alternateIdentifierType": {
                        "$ref": "https://e-rihs.io/schema/controlled_lists.schema.json#/definitions/persistent_identifier"
                    }
                }
            }
        },
        "materialTerms": {
            "title": "Materials Terms",
            "description": "The material terms related to the sample or its source.",
            "type": "array",
            "items": {
                "title": "Material",
                "type": "string",
                "cordra": {
                    "type": {
                        "handleReference": {
                            "types": ["Material"]
                        }
                    }
                }
            }
        },
        "sampleType": {
            "title": "Sample Type",
            "description": "The type of sample.",
            "type": "string",
            "$comment": "TODO: map to controlled list",
            "enum": [
                "Borehole",
                "Cross section",
                "Fragment",
                "Scraping",
                "Thin section"
            ]
        },
        "subjects": {
            "title": "Subjects, Keywords and Classification codes",
            "description": "The free-text subject property contains the 'subject, keyword, classification code, or key phrase describing the resource.' Do not use this for material terms or sample type.",
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "subject": {
                        "title": "Subject",
                        "type": "string"
                    },
                    "subjectScheme": {
                        "title": "Subject Scheme",
                        "type": "string"
                    },
                    "schemeUri": {
                        "title": "Scheme URI",
                        "type": "string",
                        "format": "uri"
                    },
                    "valueUri": {
                        "title": "Value URI",
                        "type": "string",
                        "format": "uri"
                    },
                    "classificationCode": {
                        "title": "Classification Code",
                        "type": "string"
                    },
                    "lang": {
                        "$ref": "https://e-rihs.io/schema/controlled_lists.schema.json#/definitions/operating_language"
                    }
                },
                "required": ["subject"]
            },
            "uniqueItems": true
        },
        "version": {
            "title": "Version",
            "description": "The version of the sample description. Suggested practice: track major_version.minor_version.",
            "type": "string"
        },
        "fundingReferences": {
            "title": "Funding References",
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "funderName": {
                        "title": "Funder Name",
                        "type": "string"
                    },
                    "funderIdentifier": {
                        "title": "Funder Identifier",
                        "type": "string"
                    },
                    "funderIdentifierType": {
                        "title": "Funder Identifier Type",
                        "type": "string",
                        "enum": [
                            "ISNI",
                            "GRID",
                            "Crossref Funder ID",
                            "ROR",
                            "Other"
                        ]
                    },
                    "awardNumber": {
                        "title": "Award Number",
                        "type": "string"
                    },
                    "awardUri": {
                        "title": "Award URI",
                        "type": "string",
                        "format": "uri"
                    },
                    "awardTitle": {
                        "title": "Award Title",
                        "type": "string"
                    }
                },
                "required": ["funderName"]
            },
            "uniqueItems": true
        },
        "rightsList": {
            "title": "Rights List",
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "rights": {
                        "title": "Rights",
                        "type": "string"
                    },
                    "rightsUri": {
                        "title": "Rights URI",
                        "type": "string",
                        "format": "uri"
                    },
                    "rightsIdentifier": {
                        "title": "Rights Identifier",
                        "type": "string"
                    },
                    "rightsIdentifierScheme": {
                        "title": "Rights Identifier Scheme",
                        "type": "string"
                    },
                    "schemeUri": {
                        "title": "Scheme URI",
                        "type": "string",
                        "format": "uri"
                    },
                    "lang": {
                        "$ref": "https://e-rihs.io/schema/controlled_lists.schema.json#/definitions/operating_language"
                    }
                }
            },
            "uniqueItems": true
        },
        "relatedIdentifiers": {
            "title": "Related Identifiers",
            "description": "Connecting samples to one another, and to research based on them, is a primary goal of the IGSN ID. Such connections are captured through relatedIdentifier properties, which list the globally unique Identifiers assigned to related resources. It is therefore recommended that relatedIdentifier is used to the maximum extent possible and is updated on a regular basis. Sample collections should be referenced via relationType 'IsPartOf' pointing to the collection's DOI or IGSN.",
            "type": "array",
            "options": {
                "hidden": true
            },
            "items": {
                "title": "Related Identifier",
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "relatedIdentifier",
                    "relatedIdentifierType",
                    "relationType"
                ],
                "properties": {
                    "relatedIdentifier": {
                        "title": "Related Identifier",
                        "type": "string"
                    },
                    "relatedIdentifierType": {
                        "title": "Related Identifier Type",
                        "type": "string",
                        "enum": [
                            "ARK",
                            "arXiv",
                            "bibcode",
                            "DOI",
                            "EAN13",
                            "EISSN",
                            "Handle",
                            "IGSN",
                            "ISBN",
                            "ISSN",
                            "ISTC",
                            "LISSN",
                            "LSID",
                            "PMID",
                            "PURL",
                            "UPC",
                            "URL",
                            "URN",
                            "w3id"
                        ]
                    },
                    "relationType": {
                        "title": "Relation Type",
                        "description": "The relatedIdentifier property can be used to make connections that mirror sample hierarchies. Because the parent IGSN ID is a key element in IGSN ID metadata, it is recommended that a child (sub)sample identifies its parent using the relationType 'IsPartOf' or 'IsDerivedFrom'. Vice versa, a parent sample can identify its children using 'HasPart' or 'IsSourceOf'.",
                        "type": "string",
                        "enum": [
                            "IsCitedBy",
                            "Cites",
                            "IsCollectedBy",
                            "Collects",
                            "IsSupplementTo",
                            "IsSupplementedBy",
                            "IsContinuedBy",
                            "Continues",
                            "IsDescribedBy",
                            "Describes",
                            "HasMetadata",
                            "IsMetadataFor",
                            "HasVersion",
                            "IsVersionOf",
                            "IsNewVersionOf",
                            "IsPartOf",
                            "IsPreviousVersionOf",
                            "IsPublishedIn",
                            "HasPart",
                            "IsReferencedBy",
                            "References",
                            "IsDocumentedBy",
                            "Documents",
                            "IsCompiledBy",
                            "Compiles",
                            "IsVariantFormOf",
                            "IsOriginalFormOf",
                            "IsIdenticalTo",
                            "IsReviewedBy",
                            "Reviews",
                            "IsDerivedFrom",
                            "IsSourceOf",
                            "IsRequiredBy",
                            "Requires",
                            "IsObsoletedBy",
                            "Obsoletes"
                        ]
                    },
                    "relatedMetadataScheme": {
                        "title": "Related Metadata Scheme",
                        "description": "NOTE: Use only with this relation pair: HasMetadata / IsMetadataFor",
                        "type": "string"
                    },
                    "schemeUri": {
                        "title": "Scheme URI",
                        "type": "string",
                        "description": "NOTE: Use only with this relation pair: HasMetadata / IsMetadataFor",
                        "format": "uri"
                    },
                    "schemeType": {
                        "title": "Scheme Type",
                        "type": "string",
                        "description": "NOTE: Use only with this relation pair: HasMetadata / IsMetadataFor"
                    },
                    "resourceTypeGeneral": {
                        "title": "Resource Type General",
                        "type": "string",
                        "enum": [
                            "Audiovisual",
                            "Book",
                            "BookChapter",
                            "Collection",
                            "ComputationalNotebook",
                            "ConferencePaper",
                            "ConferenceProceeding",
                            "DataPaper",
                            "Dataset",
                            "Dissertation",
                            "Event",
                            "Image",
                            "Instrument",
                            "InteractiveResource",
                            "Journal",
                            "JournalArticle",
                            "Model",
                            "OutputManagementPlan",
                            "PeerReview",
                            "PhysicalObject",
                            "Preprint",
                            "Report",
                            "Service",
                            "Software",
                            "Sound",
                            "Standard",
                            "StudyRegistration",
                            "Text",
                            "Workflow",
                            "Other"
                        ]
                    }
                }
            }
        },
        "_custodianNames": {
            "title": "Custodian Names",
            "description": "Automatically generated list of custodian names based on the titles array.",
            "type": "array",
            "items": {
                "type": "string",
                "cordra": {
                    "preview": {
                        "showInPreview": true
                    }
                }
            },
            "options": {
                "hidden": true
            }
        },
        "_sourceObject": {
            "title": "Source Object",
            "type": "string",
            "format": "json",
            "options": {
                "hidden": true
            }
        },
        "_sourceLabel": {
            "title": "Source Label",
            "type": "string",
            "description": "A short label for the source object, for display purposes.",
            "cordra": {
                "preview": {
                    "showInPreview": true
                }
            },
            "options": {
                "hidden": true
            }
        },
        "_sourceType": {
            "title": "Source Type",
            "type": "string",
            "description": "The type of heritage object from which the sample was taken",
            "cordra": {
                "preview": {
                    "showInPreview": true
                }
            },
            "options": {
                "hidden": true
            }
        }
    }
}
