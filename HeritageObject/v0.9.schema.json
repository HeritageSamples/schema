{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://heritagesamples.org/schema/HeritageObject/v0.9.schema.json",
    "title": "HeritageObject",
    "type": "object",
    "required": [
        "id",
        "types",
        "titles",
        "creators",
        "custodian",
        "publisher",
        "dates"
    ],
    "properties": {
        "id": {
            "title": "Heritage object identifier",
            "description": "The identifier property will be automatically populated with a DOI upon the creation of an IGSN ID. The system will assign a random DOI suffix unless a specific suffix is supplied using Fabrica or DataCite APIs.",
            "type": "string",
            "cordra": {
                "type": {
                    "autoGeneratedField": "handle"
                }
            }
        },
        "principalIdentifier": {
            "title": "Principal Identifier",
            "type": "object",
            "required": ["identifier", "identifierType"],
            "properties": {
                "identifier": {
                    "title": "Identifier",
                    "type": "string",
                    "format": "uri"
                },
                "identifierType": {
                    "$ref": "https://e-rihs.io/schema/controlled_lists.schema.json#/definitions/persistent_identifier"
                }
            }
        },
        "types": {
            "title": "Resource types",
            "type": "object",
            "description": "The resourceType property may be populated with resource types from external ontologies or shared vocabularies. In the absence of an agreed vocabulary, the use of the terms “material sample” or “‘feature-of-interest” are strongly recommended to at least distinguish between these sampling concepts. A material sample is a specialization of a larger feature-of-interest, which is typically the collection site. For example, in the Geosciences, a feature-of-interest might be a lake, tree, cross-section, transect, or borehole. ",
            "additionalProperties": false,
            "required": ["resourceType", "resourceTypeGeneral"],
            "properties": {
                "resourceType": {
                    "title": "Resource Type",
                    "type": "string",
                    "enum": [
                        "Heritage Object",
                        "Heritage Fragment"
                    ],
                    "$comment": "https://support.datacite.org/docs/igsn-id-metadata-recommendations#10-resourcetype"
                },
                "resourceTypeGeneral": {
                    "type": "string",
                    "const": "PhysicalObject",
                    "default": "PhysicalObject",
                    "$comment": "https://support.datacite.org/docs/igsn-id-metadata-recommendations#10a-resourcetypegeneral"
                }
            }
        },
        "titles": {
            "title": "Heritage object titles or labels",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,            
            "description": "The title property should include appropriate elements that would help find and distinguish a sample. If the title is an institutional identifier, the appropriate field should be set to true.",
            "items": {
                "title": "Heritage object title",
                "type": "object",
                "required": ["title", "titleType"],
                "additionalProperties": false,
                "properties": {
                    "title": {
                        "type": "string"
                    },
                    "titleType": {
                        "type": "string",
                        "enum": [
                            "Title",
                            "AlternativeTitle",
                            "Subtitle",
                            "TranslatedTitle",
                            "Other"
                        ],
                        "default": "Title",
                        "$comment": "https://datacite-metadata-schema.readthedocs.io/en/4.6/properties/title/#a-titletype"
                    },
                    "lang": {
                        "$ref": "https://e-rihs.io/schema/controlled_lists.schema.json#/definitions/operating_language"
                    }
                }
            }
        },
        "inventoryNumber": {
            "title": "Primary Inventory Number",
            "type": "string",
            "description": "The primary inventory number of the heritage object of the current custodian. Other inventory numbers can be added in the 'alternateIdentifiers' array."
        },
        "parentObject": {
            "title": "Parent Object",
            "description": "Optional value to define the parent object, an object or fragment was originally part of",
            "type": "string",
            "cordra": {
                "type": {
                    "handleReference": {
                        "types": ["HeritageObject"]
                    }
                }
            }
        },
        "descriptions": {
            "title": "Descriptions",
            "description": "It is valuable to include additional information about a heritage object or fragment, particularly about its creation, in the free-text description property. If the description property is used, then the sub-property descriptionType is mandatory.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["description", "descriptionType"],
                "properties": {
                    "description": {
                        "title": "Description",
                        "type": "string",
                        "format": "textarea"
                    },
                    "descriptionType": {
                        "title": "Description Type",
                        "type": "string",
                        "enum": [
                            "Object description",
                            "Subject description",
                            "Technical description",
                            "Other"
                        ],
                        "$comment": "The custom descriptionType values used here map to standard DataCite types as follows: 'Object description' should be treated as 'Abstract'; 'Subject description' maps to 'Other', but we should add a sort of title to the description (e.g. 'Subject description ##'); and 'Technical description' maps to 'TechnicalInfo'. These mappings should be applied when exporting to systems that expect standard DataCite descriptionType values."
                    },
                    "lang": {
                        "$ref": "https://e-rihs.io/schema/controlled_lists.schema.json#/definitions/operating_language"
                    }
                }
            }
        },
        "geoLocations": {
            "title": "Geo Locations",
            "description": "For real-world geospatial locations only. The geoLocation property is used to encode information on the origin of the heritage object or fragment.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "minProperties": 1,
                "properties": {
                    "geoLocationPlace": {
                        "title": "Geo Location Place",
                        "type": "string"
                    },
                    "geoLocationPoint": {
                        "$ref": "#/$defs/geoLocationPoint"
                    },
                    "geoLocationBox": {
                        "title": "Geo Location Box",
                        "type": "object",
                        "additionalProperties": false,
                        "required": [
                            "westBoundLongitude",
                            "eastBoundLongitude",
                            "southBoundLatitude",
                            "northBoundLatitude"
                        ],
                        "properties": {
                            "westBoundLongitude": {
                                "$ref": "#/$defs/longitude"
                            },
                            "eastBoundLongitude": {
                                "$ref": "#/$defs/longitude"
                            },
                            "southBoundLatitude": {
                                "$ref": "#/$defs/latitude"
                            },
                            "northBoundLatitude": {
                                "$ref": "#/$defs/latitude"
                            }
                        }
                    },
                    "geoLocationPolygon": {
                        "title": "Geo Location Polygon",
                        "type": "array",
                        "items": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "polygonPoint": {
                                    "$ref": "#/$defs/geoLocationPoint"
                                },
                                "inPolygonPoint": {
                                    "$ref": "#/$defs/geoLocationPoint"
                                }
                            }
                        }
                    }
                }
            }
        },
        "sizes": {
            "title": "Sizes",
            "description": "The dimensions of the object. This is a list of sizes in a unit of measure. This can be width, height, depth, diameter, weight, volume, etc. Use SI units as appropriate.",
            "type": "array",
            "items": {
                "type": "string"
            },
            "uniqueItems": true
        },
        "creators": {
            "title": "Creators",
            "type": "array",
            "description": "The creators are the people or group of people (workshop, tribe, etc.) that created the object (or the source object the fragment was originally part of).",
            "items": {
                "title": "Person",
                "type": "string",
                "cordra": {
                    "type": {
                        "handleReference": {
                            "types": ["Person", "Organisation"]
                        }
                    }
                }
            }
        },
        "custodian": {
            "title": "Custodian",
            "description": "The custodian organisation is the organisation or person that hosts or is responsible for the object. For long-term loans, this would still be the organisation hosting the object and not the owner.",
            "type": "string",
            "$comment": "maps to contributor with type HostingInstitution",
            "cordra": {
                "type": {
                    "handleReference": {
                        "types": ["Organisation", "Person"]
                    }
                }
            }
        },
        "publisher": {
            "title": "Publisher",
            "description": "The publisher is the organisation or person that publishes the record.",
            "type": "string",
            "cordra": {
                "type": {
                    "handleReference": {
                        "types": ["Organisation"]
                    }
                }
            }
        },
        "publicationYear": {
            "title": "Publication Year",
            "description": "The publication year is the year when the record was first made available to the research community.",
            "type": "string",
            "pattern": "^[0-9]{4}$"
        },
        "dates": {
            "title": "Dates",
            "description": "Associated dates for the sample. If the date is not known precisely, use the first of January of the year to indicate the year.",
            "type": "object",
            "required": ["publishedDate"],
            "properties": {
                "collectedDate": {
                    "title": "Created Date",
                    "description": "The created date is the date when the object was created.",
                    "type": "string",
                    "format": "date"
                },
                "acquisitionDate": {
                    "title": "Acquisition Date",
                    "description": "The acquisition date is the date when the object was acquired.",
                    "$comment": "maps to 'collected' in datacite",
                    "type": "string",
                    "format": "date"
                },
                "destroyedDate": {
                    "title": "Destroyed Date",
                    "description": "The destroyed date is the date when the object was destroyed (if it has been destroyed).",
                    "type": "string",
                    "format": "date"
                },
                "publishedDate": {
                    "title": "Published Date",
                    "description": "The published date is the date when the record was published.",
                    "type": "string",
                    "format": "date"
                }
            }
        },
        "alternateIdentifiers": {
            "title": "Alternate Identifiers",
            "description": "The alternateIdentifier property may be used to enter any other identifiers for the object, including local object identifiers.",
            "type": "array",
            "uniqueItems": true,
            "items": {
                "title": "Alternate Identifier",
                "type": "object",
                "additionalProperties": false,
                "required": ["alternateIdentifier", "alternateIdentifierType"],
                "properties": {
                    "alternateIdentifier": {
                        "title": "Alternate Identifier",
                        "type": "string"
                    },
                    "alternateIdentifierType": {
                        "$ref": "https://e-rihs.io/schema/controlled_lists.schema.json#/definitions/persistent_identifier"
                    }
                }
            }
        },
        "materialTerms": {
            "title": "Materials Terms",
            "description": "The material terms related to the object and its manufacture/creation.",
            "type": "array",
            "items": {
                "title": "Material",
                "type": "string",
                "cordra": {
                    "type": {
                        "handleReference": {
                            "types": ["VocabularyConcept"]
                        }
                    }
                }
            }
        },
        "objectType": {
            "title": "Object Type",
            "description": "The type of object.",
            "type": "string",
            "$comment": "TODO: map to controlled list",
            "enum": [
                "Painting",
                "Archeological artefact"
            ]
        },
        "subjects": {
            "title": "Subjects, Keywords and Classification codes",
            "description": "The free-text subject property contains the 'subject, keyword, classification code, or key phrase describing the resource.' Do not use this for material terms or object type.",
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "subject": {
                        "title": "Subject",
                        "type": "string"
                    },
                    "subjectScheme": {
                        "title": "Subject Scheme",
                        "type": "string"
                    },
                    "schemeUri": {
                        "title": "Scheme URI",
                        "type": "string",
                        "format": "uri"
                    },
                    "valueUri": {
                        "title": "Value URI",
                        "type": "string",
                        "format": "uri"
                    },
                    "classificationCode": {
                        "title": "Classification Code",
                        "type": "string"
                    },
                    "lang": {
                        "$ref": "https://e-rihs.io/schema/controlled_lists.schema.json#/definitions/operating_language"
                    }
                },
                "required": ["subject"]
            },
            "uniqueItems": true
        },
        "version": {
            "title": "Version",
            "description": "The version of the sample description. Suggested practice: track major_version.minor_version.",
            "type": "string"
        },
        "fundingReferences": {
            "title": "Funding References",
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "funderName": {
                        "title": "Funder Name",
                        "type": "string"
                    },
                    "funderIdentifier": {
                        "title": "Funder Identifier",
                        "type": "string"
                    },
                    "funderIdentifierType": {
                        "title": "Funder Identifier Type",
                        "type": "string",
                        "enum": ["ISNI", "GRID", "Crossref Funder ID", "ROR", "Other"]
                    },
                    "awardNumber": {
                        "title": "Award Number",
                        "type": "string"
                    },
                    "awardUri": {
                        "title": "Award URI",
                        "type": "string",
                        "format": "uri"
                    },
                    "awardTitle": {
                        "title": "Award Title",
                        "type": "string"
                    }
                },
                "required": ["funderName"]
            },
            "uniqueItems": true
        },
        "rightsList": {
            "title": "Rights List",
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "rights": {
                        "title": "Rights",
                        "type": "string"
                    },
                    "rightsUri": {
                        "title": "Rights URI",
                        "type": "string",
                        "format": "uri"
                    },
                    "rightsIdentifier": {
                        "title": "Rights Identifier",
                        "type": "string"
                    },
                    "rightsIdentifierScheme": {
                        "title": "Rights Identifier Scheme",
                        "type": "string"
                    },
                    "schemeUri": {
                        "title": "Scheme URI",
                        "type": "string",
                        "format": "uri"
                    },
                    "lang": {
                        "$ref": "https://e-rihs.io/schema/controlled_lists.schema.json#/definitions/operating_language"
                    }
                }
            },
            "uniqueItems": true
        },
        "relatedIdentifiers": {
            "title": "Related Identifiers",
            "description": "Connecting objects to one another, and to research based on them, is a primary goal of the DOIs. Such connections are captured through relatedIdentifier properties, which list the globally unique Identifiers assigned to related resources. It is therefore recommended that relatedIdentifier is used to the maximum extent possible and is updated on a regular basis.",
            "type": "array",
            "options": {
                "hidden": true
            },
            "items": {
                "title": "Related Identifier",
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "relatedIdentifier",
                    "relatedIdentifierType",
                    "relationType"
                ],
                "properties": {
                    "relatedIdentifier": {
                        "title": "Related Identifier",
                        "type": "string"
                    },
                    "relatedIdentifierType": {
                        "title": "Related Identifier Type",
                        "type": "string",
                        "enum": [
                            "ARK",
                            "arXiv",
                            "bibcode",
                            "DOI",
                            "EAN13",
                            "EISSN",
                            "Handle",
                            "IGSN",
                            "ISBN",
                            "ISSN",
                            "ISTC",
                            "LISSN",
                            "LSID",
                            "PMID",
                            "PURL",
                            "UPC",
                            "URL",
                            "URN",
                            "w3id"
                        ]
                    },
                    "relationType": {
                        "title": "Relation Type",
                        "description": "The relatedIdentifier property can be used to make connections that mirror sample hierarchies. Because the parent IGSN ID is a key element in IGSN ID metadata, it is recommended that a child (sub)sample identifies its parent using the relationType 'IsPartOf' or 'IsDerivedFrom'. Vice versa, a parent sample can identify its children using 'HasPart' or 'IsSourceOf'.",
                        "type": "string",
                        "enum": [
                            "IsCitedBy",
                            "Cites",
                            "IsCollectedBy",
                            "Collects",
                            "IsSupplementTo",
                            "IsSupplementedBy",
                            "IsContinuedBy",
                            "Continues",
                            "IsDescribedBy",
                            "Describes",
                            "HasMetadata",
                            "IsMetadataFor",
                            "HasVersion",
                            "IsVersionOf",
                            "IsNewVersionOf",
                            "IsPartOf",
                            "IsPreviousVersionOf",
                            "IsPublishedIn",
                            "HasPart",
                            "IsReferencedBy",
                            "References",
                            "IsDocumentedBy",
                            "Documents",
                            "IsCompiledBy",
                            "Compiles",
                            "IsVariantFormOf",
                            "IsOriginalFormOf",
                            "IsIdenticalTo",
                            "IsReviewedBy",
                            "Reviews",
                            "IsDerivedFrom",
                            "IsSourceOf",
                            "IsRequiredBy",
                            "Requires",
                            "IsObsoletedBy",
                            "Obsoletes"
                        ]
                    },
                    "relatedMetadataScheme": {
                        "title": "Related Metadata Scheme",
                        "description": "NOTE: Use only with this relation pair: HasMetadata / IsMetadataFor",
                        "type": "string"
                    },
                    "schemeUri": {
                        "title": "Scheme URI",
                        "type": "string",
                        "description": "NOTE: Use only with this relation pair: HasMetadata / IsMetadataFor",
                        "format": "uri"
                    },
                    "schemeType": {
                        "title": "Scheme Type",
                        "type": "string",
                        "description": "NOTE: Use only with this relation pair: HasMetadata / IsMetadataFor"
                    },
                    "resourceTypeGeneral": {
                        "title": "Resource Type General",
                        "type": "string",
                        "enum": [
                            "Audiovisual",
                            "Book",
                            "BookChapter",
                            "Collection",
                            "ComputationalNotebook",
                            "ConferencePaper",
                            "ConferenceProceeding",
                            "DataPaper",
                            "Dataset",
                            "Dissertation",
                            "Event",
                            "Image",
                            "Instrument",
                            "InteractiveResource",
                            "Journal",
                            "JournalArticle",
                            "Model",
                            "OutputManagementPlan",
                            "PeerReview",
                            "PhysicalObject",
                            "Preprint",
                            "Report",
                            "Service",
                            "Software",
                            "Sound",
                            "Standard",
                            "StudyRegistration",
                            "Text",
                            "Workflow",
                            "Other"
                        ]
                    }
                }
            }
        },
        "_displayTitle": {
            "title": "Display Title",
            "description": "Automatically generated title based on the titles array.",
            "type": "string",
            "options": {
                "hidden": true
            }
        }
    },
    "$defs": {
        "geoLocationPoint": {
            "title": "Geo Location Point",
            "type": "object",
            "additionalProperties": false,
            "required": ["pointLongitude", "pointLatitude"],
            "properties": {
                "pointLongitude": {
                    "$ref": "#/$defs/longitude"
                },
                "pointLatitude": {
                    "$ref": "#/$defs/latitude"
                }
            }
        },
        "latitude": {
            "type": "number",
            "maximum": 90,
            "minimum": -90
        },
        "longitude": {
            "type": "number",
            "maximum": 180,
            "minimum": -180
        }
    }
}
